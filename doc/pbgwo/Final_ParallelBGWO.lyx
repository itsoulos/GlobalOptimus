\begin_layout Plain Layout
\begin_inset Caption Standard

\begin_layout Plain Layout
Communication Strategy with 20 Subpopulations.
\begin_inset CommandInset label
LatexCommand label
name "fig:Communication-Strategy-with-1"

\end_inset


\end_layout

\end_inset


