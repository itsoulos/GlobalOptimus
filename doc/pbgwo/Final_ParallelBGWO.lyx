\begin_layout Plain Layout
\begin_inset Caption Standard

\begin_layout Plain Layout
Communication Strategy with 10 Subpopulations.
\begin_inset CommandInset label
LatexCommand label
name "fig:Communication-Strategy-with"

\end_inset


